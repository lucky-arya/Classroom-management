# ============================================
# College Dashboard - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# --- Database ---
# NeonDB PostgreSQL connection string
# Get it from: https://console.neon.tech/
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Better Auth ---
# A strong random secret key for session signing
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your-strong-random-secret-here

# --- CORS / URLs ---
# Frontend URL (for CORS and trusted origins)
FRONTEND_URL=http://localhost:5173

# --- Server ---
# Optional: Port to run the server on (default: 8000)
PORT=8000

# --- Social Auth Credentials (Google / GitHub OAuth) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
