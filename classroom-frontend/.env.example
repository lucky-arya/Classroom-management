# ============================================
# College Dashboard - Frontend Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# --- Backend API URL ---
# The base URL for the backend API (including /api prefix)
VITE_BACKEND_BASE_URL=http://localhost:8000/api

# --- Cloudinary ---
# Your Cloudinary cloud name (found in the Cloudinary dashboard)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Your Cloudinary unsigned upload preset
# Create one at: Cloudinary > Settings > Upload > Upload presets
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Your Cloudinary upload URL (replace YOUR_CLOUD_NAME)
VITE_CLOUDINARY_UPLOAD_URL=https://api.cloudinary.com/v1_1/YOUR_CLOUD_NAME/image/upload
